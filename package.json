{
    "name": "finance-manager-monorepo",
    "private": true,
    "description": "Personal Finance Ledger with Splits and Daily Reports",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "build:api": "turbo build --filter=@finance/api...",
        "db:generate": "npm run generate --workspace=@finance/db",
        "db:migrate": "npm run migrate --workspace=@finance/db",
        "db:push": "npm run push --workspace=@finance/db",
        "db:seed": "npm run seed --workspace=@finance/db",
        "db:wipe": "npm run wipe --workspace=@finance/db"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "turbo": "latest",
        "typescript": "^5.7.3"
    },
    "packageManager": "npm@10.8.2"
}